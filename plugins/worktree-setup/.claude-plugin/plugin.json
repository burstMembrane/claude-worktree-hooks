{
  "name": "worktree-setup",
  "version": "0.1.0",
  "description": "Automated worktree setup and teardown for Claude Code parallel sessions",
  "author": {
    "name": "Liam Power"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-create.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-remove.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}