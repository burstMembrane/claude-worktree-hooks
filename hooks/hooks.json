{
  "description": "Worktree lifecycle hooks for automated setup and teardown",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/worktree-create.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/worktree-remove.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
